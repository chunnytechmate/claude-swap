#!/usr/bin/env bash
#
# claude-swap — switch ~/.claude/settings.json between named profiles.
#
#   claude-swap              interactive picker (arrow keys) — status if piped
#   claude-swap <name>       switch to profile <name>   (e.g. zai, claude)
#   claude-swap list         list available profiles
#   claude-swap status       show active profile and drift check
#   claude-swap which        print the active profile name only (scriptable)
#   claude-swap edit <name>  open a profile in $EDITOR
#   claude-swap changekey [name]  replace the API key in a profile (default zai)
#   claude-swap update       update claude-swap itself from GitHub
#   claude-swap help
#
# Profiles live in ~/.claude/profiles/<name>.json — each is a COMPLETE
# settings.json. The active one is copied to ~/.claude/settings.json.
#
set -euo pipefail

VERSION="1.5.0"
REPO_RAW="${CLAUDE_SWAP_REPO_RAW:-https://raw.githubusercontent.com/chunnytechmate/claude-swap/main}"

# --- paths (override root with CLAUDE_SWAP_HOME for testing) --------------
CLAUDE_DIR="${CLAUDE_SWAP_HOME:-$HOME/.claude}"
SETTINGS="$CLAUDE_DIR/settings.json"
PROFILES_DIR="$CLAUDE_DIR/profiles"
BACKUP_DIR="$PROFILES_DIR/.backups"
ACTIVE_MARKER="$PROFILES_DIR/.active"
MAX_BACKUPS=10

# --- colors (only when writing to a terminal) ----------------------------
if [ -t 1 ]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RED=$'\033[31m'; GRN=$'\033[32m'
  YLW=$'\033[33m'; CYN=$'\033[36m'; RST=$'\033[0m'
else
  BOLD=""; DIM=""; RED=""; GRN=""; YLW=""; CYN=""; RST=""
fi

info() { printf '%s\n' "$*"; }
err()  { printf '%serror:%s %s\n' "$RED" "$RST" "$*" >&2; }
die()  { err "$*"; exit 1; }

# --- helpers -------------------------------------------------------------
json_valid() {
  # 0 if $1 is valid JSON (or if no validator is available)
  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import json,sys; json.load(open(sys.argv[1]))' "$1" 2>/dev/null
  elif command -v jq >/dev/null 2>&1; then
    jq -e . "$1" >/dev/null 2>&1
  else
    return 0
  fi
}

hash_file() {
  [ -f "$1" ] || { printf 'MISSING'; return; }
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$1" | awk '{print $1}'
  else
    wc -c < "$1" | tr -d ' '
  fi
}

profile_path() { printf '%s/%s.json' "$PROFILES_DIR" "$1"; }

# security: profile names may not traverse paths or start with a dot
valid_name() { [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]]; }

list_profiles() {
  [ -d "$PROFILES_DIR" ] || return 0
  local f b
  for f in "$PROFILES_DIR"/*.json; do
    [ -e "$f" ] || continue
    b=$(basename "$f")
    printf '%s\n' "${b%.json}"
  done
}

marker_profile() {
  [ -f "$ACTIVE_MARKER" ] && tr -d '[:space:]' < "$ACTIVE_MARKER" || printf ''
}

# Best-effort detection of which profile settings.json currently matches.
matched_profile() {
  [ -f "$SETTINGS" ] || { printf ''; return; }
  local want p
  want=$(hash_file "$SETTINGS")
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    if [ "$(hash_file "$(profile_path "$p")")" = "$want" ]; then
      printf '%s\n' "$p"; return
    fi
  done < <(list_profiles)
  printf ''
}

prune_backups() {
  [ -d "$BACKUP_DIR" ] || return 0
  local files
  # newest first; delete everything past MAX_BACKUPS
  files=$(ls -1t "$BACKUP_DIR"/settings.*.json 2>/dev/null || true)
  [ -n "$files" ] || return 0
  printf '%s\n' "$files" | tail -n +$((MAX_BACKUPS + 1)) | while IFS= read -r f; do
    [ -n "$f" ] && rm -f "$f"
  done
}

# --- commands ------------------------------------------------------------
cmd_list() {
  local profiles marker
  profiles=$(list_profiles)
  marker=$(marker_profile)
  [ -n "$profiles" ] || { info "${DIM}no profiles in $PROFILES_DIR${RST}"; return; }
  local p
  while IFS= read -r p; do
    if [ "$p" = "$marker" ]; then
      printf '  %s* %s%s\n' "$GRN" "$p" "$RST"
    else
      printf '    %s\n' "$p"
    fi
  done <<< "$profiles"
}

cmd_status() {
  local marker matched
  marker=$(marker_profile)
  matched=$(matched_profile)

  if [ -n "$marker" ]; then
    printf '%sactive:%s %s%s%s\n' "$BOLD" "$RST" "$CYN" "$marker" "$RST"
  elif [ -n "$matched" ]; then
    printf '%sactive:%s %s%s%s %s(detected)%s\n' "$BOLD" "$RST" "$CYN" "$matched" "$RST" "$DIM" "$RST"
  else
    printf '%sactive:%s %s(unknown — settings.json matches no profile)%s\n' "$BOLD" "$RST" "$YLW" "$RST"
  fi

  # drift: marker says X but settings.json no longer matches X
  if [ -n "$marker" ] && [ -f "$(profile_path "$marker")" ]; then
    if [ "$(hash_file "$SETTINGS")" != "$(hash_file "$(profile_path "$marker")")" ]; then
      printf '%s⚠ settings.json has been edited since the last swap (drift from profile %s).%s\n' \
        "$YLW" "$marker" "$RST"
      printf '  %sRun `claude-swap %s` to reset, or `claude-swap save %s` to capture edits.%s\n' \
        "$DIM" "$marker" "$marker" "$RST"
    fi
  fi

  printf '\n%sprofiles:%s\n' "$BOLD" "$RST"
  cmd_list
}

cmd_switch() {
  local name="$1" target ts tmp
  valid_name "$name" || die "invalid profile name: '$name' (letters, digits, . _ - only)"
  target=$(profile_path "$name")
  [ -f "$target" ] || die "profile '$name' not found — run: claude-swap list"
  json_valid "$target" || die "profile '$name' is not valid JSON: $target"

  mkdir -p "$PROFILES_DIR" "$BACKUP_DIR"
  chmod 700 "$PROFILES_DIR" "$BACKUP_DIR" 2>/dev/null || true

  # back up whatever is live now
  if [ -f "$SETTINGS" ]; then
    if [ "$(hash_file "$SETTINGS")" = "$(hash_file "$target")" ]; then
      info "${GRN}✓${RST} already on ${BOLD}$name${RST}"
      printf '%s' "$name" > "$ACTIVE_MARKER"
      return
    fi
    ts=$(date +%Y%m%d-%H%M%S)
    cp -p "$SETTINGS" "$BACKUP_DIR/settings.$ts.json"
    chmod 600 "$BACKUP_DIR/settings.$ts.json" 2>/dev/null || true   # may hold an API token
    prune_backups
  fi

  # atomic install: stage in same dir, validate, then move into place
  tmp=$(mktemp "$CLAUDE_DIR/.settings.XXXXXX")
  cat "$target" > "$tmp"
  if ! json_valid "$tmp"; then rm -f "$tmp"; die "staged settings invalid — aborted, settings.json untouched"; fi
  mv -f "$tmp" "$SETTINGS"
  printf '%s' "$name" > "$ACTIVE_MARKER"
  info "${GRN}✓${RST} switched to ${BOLD}$name${RST}  ${DIM}→ $SETTINGS${RST}"
  info "${DIM}  restart Claude Code / reload the window for env changes to take effect.${RST}"
}

cmd_save() {
  # capture the current live settings.json back into a profile
  local name="$1"
  [ -n "$name" ] || die "usage: claude-swap save <name>"
  valid_name "$name" || die "invalid profile name: '$name' (letters, digits, . _ - only)"
  [ -f "$SETTINGS" ] || die "no settings.json to save"
  json_valid "$SETTINGS" || die "current settings.json is not valid JSON"
  mkdir -p "$PROFILES_DIR"
  chmod 700 "$PROFILES_DIR" 2>/dev/null || true
  cp -p "$SETTINGS" "$(profile_path "$name")"
  chmod 600 "$(profile_path "$name")" 2>/dev/null || true
  printf '%s' "$name" > "$ACTIVE_MARKER"
  info "${GRN}✓${RST} saved current settings.json to profile ${BOLD}$name${RST}"
}

cmd_edit() {
  local name="$1" target
  [ -n "$name" ] || die "usage: claude-swap edit <name>"
  valid_name "$name" || die "invalid profile name: '$name' (letters, digits, . _ - only)"
  target=$(profile_path "$name")
  [ -f "$target" ] || die "profile '$name' not found"
  "${EDITOR:-vi}" "$target"
  json_valid "$target" || err "warning: '$name' is no longer valid JSON"
}

# Replace only env.<field> in a profile JSON, preserving everything else.
# The key is never passed via argv (env var for python3; a temp file for jq).
# Returns 0 on success, nonzero otherwise.
update_token() {  # dest key field
  local dest="$1" key="$2" field="$3" kf
  if command -v python3 >/dev/null 2>&1; then
    KEY="$key" DEST="$dest" FIELD="$field" python3 - <<'PY' || { rm -f "$dest.tmp"; return 1; }
import json, os
p = os.environ['DEST']
d = json.load(open(p))
d.setdefault('env', {})[os.environ['FIELD']] = os.environ['KEY']
with open(p + '.tmp', 'w') as f:
    json.dump(d, f, indent=2); f.write('\n')
PY
    mv -f "$dest.tmp" "$dest" || return 1
    return 0
  fi
  if command -v jq >/dev/null 2>&1; then
    kf=$(mktemp) || return 1
    printf '%s' "$key" > "$kf"; chmod 600 "$kf"
    jq --rawfile k "$kf" --arg f "$field" '.env[$f] = ($k|rtrimstr("\n"))' "$dest" > "$dest.tmp" \
      || { rm -f "$kf" "$dest.tmp"; return 1; }
    rm -f "$kf"
    mv -f "$dest.tmp" "$dest" || return 1
    return 0
  fi
  return 2  # no JSON tooling available
}

cmd_changekey() {
  local name="${1:-zai}" target field
  valid_name "$name" || die "invalid profile name: '$name' (letters, digits, . _ - only)"
  target=$(profile_path "$name")
  [ -f "$target" ] || die "profile '$name' not found — run: claude-swap list"

  # which key field does this profile use?
  if   grep -q '"ANTHROPIC_AUTH_TOKEN"' "$target"; then field=ANTHROPIC_AUTH_TOKEN
  elif grep -q '"ANTHROPIC_API_KEY"'    "$target"; then field=ANTHROPIC_API_KEY
  else die "profile '$name' has no ANTHROPIC_AUTH_TOKEN / ANTHROPIC_API_KEY field — try: claude-swap edit $name"; fi

  # hidden input from the terminal (fall back to stdin for pipes/tests)
  local in=0; if { exec 3</dev/tty; } 2>/dev/null; then in=3; fi
  local key ans masked
  printf '%sChange API key for %s%s  %s(%s)%s\n' "$BOLD" "$name" "$RST" "$DIM" "$field" "$RST"
  printf 'Enter new API key %s(blank to cancel)%s: ' "$DIM" "$RST"
  if [ "$in" = 3 ]; then IFS= read -r -s key <&3 || key=""; else IFS= read -r -s key || key=""; fi
  printf '\n'
  [ -n "$key" ] || { [ "$in" = 3 ] && exec 3<&-; info "${DIM}cancelled — no changes${RST}"; return 0; }

  if [ "${#key}" -gt 12 ]; then masked="${key:0:6}…${key: -4}"; else masked="********"; fi
  printf 'Save key %s%s%s to %s? [y/N] ' "$BOLD" "$masked" "$RST" "$name"
  if [ "$in" = 3 ]; then IFS= read -r ans <&3 || ans=""; else IFS= read -r ans || ans=""; fi
  case "$ans" in
    y|Y|yes|YES|Yes) ;;
    *) [ "$in" = 3 ] && exec 3<&-; info "${DIM}cancelled — no changes${RST}"; return 0 ;;
  esac
  [ "$in" = 3 ] && exec 3<&-

  if ! update_token "$target" "$key" "$field"; then
    die "failed to update '$name' (install python3 or jq, or use: claude-swap edit $name)"
  fi
  chmod 600 "$target" 2>/dev/null || true
  info "${GRN}✓${RST} updated ${BOLD}$field${RST} in profile ${BOLD}$name${RST}  ${DIM}($target)${RST}"

  # if this is the active profile, re-deploy so the new key takes effect now
  if [ "$(marker_profile)" = "$name" ]; then
    mkdir -p "$BACKUP_DIR"; chmod 700 "$BACKUP_DIR" 2>/dev/null || true
    if [ -f "$SETTINGS" ]; then
      ts=$(date +%Y%m%d-%H%M%S)
      cp -p "$SETTINGS" "$BACKUP_DIR/settings.$ts.json"
      chmod 600 "$BACKUP_DIR/settings.$ts.json" 2>/dev/null || true
      prune_backups
    fi
    local tmp; tmp=$(mktemp "$CLAUDE_DIR/.settings.XXXXXX")
    cat "$target" > "$tmp"
    if json_valid "$tmp"; then
      mv -f "$tmp" "$SETTINGS"
      info "${DIM}  also applied to live settings.json ($name is active)${RST}"
    else
      rm -f "$tmp"
      info "${YLW}  profile is active but settings.json was NOT updated (invalid JSON)${RST}"
    fi
    info "${DIM}  restart Claude Code / reload the window for the change to take effect.${RST}"
  else
    info "${DIM}  (not active — run 'claude-swap $name' to apply)${RST}"
  fi
}

# Interactive arrow-key picker (ANSI redraw). Renders to stderr; sets REPLY_PROFILE.
# Returns 1 if cancelled. Reads keys from the terminal (falls back to stdin).
REPLY_PROFILE=""
interactive_pick() {
  local -a opts=()
  local p
  while IFS= read -r p; do [ -n "$p" ] && opts+=("$p"); done < <(list_profiles)
  [ "${#opts[@]}" -gt 0 ] || die "no profiles in $PROFILES_DIR — run: claude-swap help"

  # input source: prefer the controlling terminal, else stdin (for pipes/tests)
  local in=0
  if { exec 3</dev/tty; } 2>/dev/null; then in=3; fi

  local active cur=0 i
  active=$(marker_profile)
  for i in "${!opts[@]}"; do [ "${opts[$i]}" = "$active" ] && cur=$i; done

  local anim=false; [ -t 2 ] && anim=true
  _render() {
    for i in "${!opts[@]}"; do
      printf '\033[2K\r' >&2   # clear line
      if [ "$i" -eq "$cur" ]; then
        printf '  %s>%s %s%s%s' "$CYN" "$RST" "$BOLD" "${opts[$i]}" "$RST" >&2
      else
        printf '    %s' "${opts[$i]}" >&2
      fi
      [ "${opts[$i]}" = "$active" ] && printf '  %s(active)%s' "$DIM" "$RST" >&2
      printf '\n' >&2
    done
  }

  printf '%sSelect a profile%s  %s(Up/Down or j/k, Enter to switch, q to cancel)%s\n' \
    "$BOLD" "$RST" "$DIM" "$RST" >&2
  $anim && printf '\033[?25l' >&2   # hide cursor
  _render

  local key k2
  while IFS= read -rsn1 -u "$in" key 2>/dev/null; do
    case "$key" in
      $'\x1b')
        read -rsn2 -u "$in" k2 2>/dev/null || k2=""
        case "$k2" in
          '[A'|'OA') cur=$(( (cur - 1 + ${#opts[@]}) % ${#opts[@]} )) ;;
          '[B'|'OB') cur=$(( (cur + 1) % ${#opts[@]} )) ;;
          '') $anim && printf '\033[?25h' >&2; [ "$in" = 3 ] && exec 3<&-; return 1 ;;  # lone Esc
        esac ;;
      q|Q) $anim && printf '\033[?25h' >&2; [ "$in" = 3 ] && exec 3<&-; return 1 ;;
      k)   cur=$(( (cur - 1 + ${#opts[@]}) % ${#opts[@]} )) ;;
      j)   cur=$(( (cur + 1) % ${#opts[@]} )) ;;
      '')  break ;;  # Enter
    esac
    $anim && printf '\033[%dA' "${#opts[@]}" >&2   # move cursor back up to redraw
    _render
  done
  $anim && printf '\033[?25h' >&2
  [ "$in" = 3 ] && exec 3<&-
  REPLY_PROFILE="${opts[$cur]}"
  return 0
}

cmd_update() {
  local self tmp url="$REPO_RAW/bin/claude-swap"
  # update the actual running script (resolve symlinks), not whatever is first on PATH
  self="${BASH_SOURCE[0]}"
  command -v readlink >/dev/null 2>&1 && self=$(readlink -f "$self" 2>/dev/null || printf '%s' "$self")
  [ -w "$self" ] || die "cannot write to $self (check permissions; try: sudo)"
  [ -w "$(dirname "$self")" ] || die "cannot write to $(dirname "$self") (check permissions)"

  # security: https only, unless the source was explicitly overridden (testing/forks)
  case "$url" in
    https://*) ;;
    *) [ -n "${CLAUDE_SWAP_REPO_RAW:-}" ] || die "refusing non-https update source: $url"
       info "${YLW}!${RST} using overridden update source: ${DIM}$url${RST}" ;;
  esac

  info "${DIM}fetching latest from $url${RST}"
  tmp=$(mktemp)
  if command -v curl >/dev/null 2>&1; then
    # default source: enforce https end-to-end (incl. redirects) and TLS >= 1.2
    local -a cflags=(-fsSL --proto '=https' --tlsv1.2)
    [ -n "${CLAUDE_SWAP_REPO_RAW:-}" ] && cflags=(-fsSL)
    curl "${cflags[@]}" "$url" -o "$tmp" || { rm -f "$tmp"; die "download failed (curl)"; }
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$tmp" "$url" || { rm -f "$tmp"; die "download failed (wget)"; }
  else
    rm -f "$tmp"; die "need curl or wget to update"
  fi

  # integrity gate: everything must pass before we touch the installed file
  head -1 "$tmp" | grep -q '^#!/usr/bin/env bash' \
    || { rm -f "$tmp"; die "downloaded file doesn't look like claude-swap — aborted"; }
  grep -q '^VERSION="' "$tmp" \
    || { rm -f "$tmp"; die "downloaded file has no version marker — aborted"; }
  [ "$(wc -c < "$tmp")" -ge 4096 ] \
    || { rm -f "$tmp"; die "downloaded file is suspiciously small (truncated?) — aborted"; }
  bash -n "$tmp" 2>/dev/null \
    || { rm -f "$tmp"; die "downloaded file failed the bash syntax check — aborted"; }

  local newver; newver=$(grep -m1 '^VERSION=' "$tmp" | cut -d'"' -f2)
  if [ "$newver" = "$VERSION" ]; then
    rm -f "$tmp"
    info "${GRN}✓${RST} already up to date ${DIM}($VERSION)${RST}"
    return
  fi

  # atomic replace: stage next to the target, then mv (new inode — safe while running)
  local staged="$self.new.$$"
  cp "$tmp" "$staged" && chmod 0755 "$staged" && mv -f "$staged" "$self" \
    || { rm -f "$tmp" "$staged"; die "failed to install update — original left untouched"; }
  rm -f "$tmp"
  info "${GRN}✓${RST} updated claude-swap ${DIM}$VERSION${RST} → ${BOLD}${newver:-?}${RST}  ${DIM}($self)${RST}"
}

usage() {
  cat <<EOF
${BOLD}claude-swap${RST} $VERSION — switch ~/.claude/settings.json between named profiles

${BOLD}usage:${RST}
  claude-swap                 interactive picker (arrow keys) — status if piped
  claude-swap ${CYN}<name>${RST}          switch to a profile (e.g. ${CYN}zai${RST}, ${CYN}claude${RST})
  claude-swap list            list profiles
  claude-swap status          show active profile + drift check
  claude-swap which           print active profile name only
  claude-swap save ${CYN}<name>${RST}     save current settings.json into a profile
  claude-swap edit ${CYN}<name>${RST}     open a profile in \$EDITOR
  claude-swap changekey ${CYN}[name]${RST}   replace the API key in a profile (default zai)
  claude-swap update          update claude-swap itself from GitHub
  claude-swap help

profiles dir: $PROFILES_DIR
EOF
}

# --- dispatch ------------------------------------------------------------
if [ $# -eq 0 ]; then
  # no arguments: interactive picker on a terminal, plain status otherwise
  if { exec 3</dev/tty; } 2>/dev/null; then
    exec 3<&-
    if interactive_pick; then cmd_switch "$REPLY_PROFILE"; else info "${DIM}cancelled${RST}"; fi
  else
    cmd_status
  fi
  exit 0
fi

cmd="$1"
case "$cmd" in
  status|--status)   cmd_status ;;
  list|ls|--list)    cmd_list ;;
  which)             marker_profile; echo ;;
  save)              cmd_save "${2:-}" ;;
  edit)              cmd_edit "${2:-}" ;;
  changekey|change-key|key)  cmd_changekey "${2:-}" ;;
  pick|menu)         if interactive_pick; then cmd_switch "$REPLY_PROFILE"; else info "${DIM}cancelled${RST}"; fi ;;
  update|upgrade)    cmd_update ;;
  help|-h|--help)    usage ;;
  version|-v|--version) echo "claude-swap $VERSION" ;;
  -*)                die "unknown option: $cmd (try: claude-swap help)" ;;
  *)                 cmd_switch "$cmd" ;;
esac
